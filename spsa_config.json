{
  "concurrency": 12,
  "report_every": 50,
  "state_file": "spsa_state.json",
  "history_file": "spsa_history.csv",

  "spsa": {
    "pairs": 30000,
    "alpha": 0.602,
    "gamma": 0.101
  },

  "fastchess": {
    "binary": "fastchess",
    "engine": "./engine",
    "tc": "10+0.1",
    "threads": 1,
    "hash": 16,
    "openings": "./openings.epd",
    "book_format": "epd",
    "pair_timeout_sec": 1200,
    "extra_args": ""
  },

  "parameters": {
    "lmr_base":       { "start": 75,   "min": 40,   "max": 150,   "c_end": 6,   "r_end": 0.002 },
    "lmr_div":        { "start": 225,  "min": 120,  "max": 400,   "c_end": 12,  "r_end": 0.002 },
    "lmr_noisy_base": { "start": -15,  "min": -100, "max": 80,    "c_end": 9,   "r_end": 0.002 },
    "lmr_noisy_div":  { "start": 315,  "min": 150,  "max": 500,   "c_end": 15,  "r_end": 0.002 },

    "history_div":    { "start": 4140, "min": 1024, "max": 16384, "c_end": 500, "r_end": 0.002, "enabled": false },
    "lmp_base":       { "start": 453,  "min": 150,  "max": 900,   "c_end": 35,  "r_end": 0.002, "enabled": false },
    "lmp_mul":        { "start": 222,  "min": 80,   "max": 450,   "c_end": 18,  "r_end": 0.002, "enabled": false },
    "lmp_improve":    { "start": 221,  "min": 60,   "max": 400,   "c_end": 18,  "r_end": 0.002, "enabled": false },
    "futility_mul":   { "start": 168,  "min": 80,   "max": 350,   "c_end": 13,  "r_end": 0.002, "enabled": false }
  }
}
